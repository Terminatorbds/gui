# Port number
PORT=3000

# Public backend URL used in email links
BACKEND_URL=http://localhost:3000

# URL of the Mongo DB
MONGODB_URL=mongodb://127.0.0.1:27017/pm-nodejs

# Frontend URLs used in emails
FRONTEND_URL=http://localhost:5173
FRONTEND_PROFILE_PATH=/profile
FRONTEND_RESET_PASSWORD_PATH=/reset-password
FRONTEND_VERIFY_EMAIL_PATH=/verify-email

# JWT
# JWT secret key
JWT_SECRET=thisisasamplesecret
# Number of minutes after which an access token expires
JWT_ACCESS_EXPIRATION_MINUTES=30
# Number of days after which a refresh token expires
JWT_REFRESH_EXPIRATION_DAYS=30
# Number of minutes after which a reset password token expires
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
# Number of minutes after which a verify email token expires
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=10

# SMTP configuration options for the email service
# Local development defaults for MailDev.
# Start MailDev locally with: yarn mail:dev
# Or run only the Docker mailbox with: yarn mail:dev:docker
# Then open http://localhost:1080 to inspect sent emails.
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@pm-nodejs.local
